# Copy this file to a local, untracked .env file when needed.
# Keep real secrets out of Git.

AI_AGENT_LAB_ENV=local
AI_AGENT_LAB_MACHINE=local-linux
AI_AGENT_LAB_DATA_DIR=/tmp/ai-agent-lab-data
